# Supabase — required for Google OAuth and Feedback storage
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Cloudflare Turnstile — bot protection on the signup form.
# Create a free Turnstile site at https://dash.cloudflare.com → Turnstile
# (add localhost + your production hostname to the site's allowed domains).
# VITE_TURNSTILE_SITE_KEY is public (client widget). TURNSTILE_SECRET_KEY is
# server-only — NO VITE_ prefix — used by /api/verify-turnstile.
# If VITE_TURNSTILE_SITE_KEY is unset, the widget + verification are skipped
# (dev/build won't break); enforcement is active wherever the key is present.
VITE_TURNSTILE_SITE_KEY=YOUR_TURNSTILE_SITE_KEY
TURNSTILE_SECRET_KEY=YOUR_TURNSTILE_SECRET_KEY

# Notes:
# 1. The EmailJS credentials for the feedback form are embedded in the
#    client (service/template/public key are meant to be public).
# 2. After setting these vars, configure the following in Supabase:
#    - Authentication → Providers → Google: enable and add OAuth client
#    - Authentication → URL Config: add your site origin to Redirect URLs
#    - Run the `feedback` table SQL (see README / task brief)
