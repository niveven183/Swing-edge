# Copy this file to .env and fill in your keys.
# Market data uses Yahoo Finance (free), so no key needed to start.

# Optional: LLM providers (only if you wire up agents to an LLM)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: news/sentiment APIs
NEWSAPI_KEY=
FINNHUB_KEY=

# Pipeline config
LOG_LEVEL=INFO
CACHE_TTL_SECONDS=3600
